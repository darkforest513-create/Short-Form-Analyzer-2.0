# ===========================================
# Whop environment variables
# ===========================================
# 1. Copy this file:  cp .env.example .env.local
# 2. Get your values from: https://whop.com/dashboard/developer/
# 3. Create or select your app → open "Environment variables" / "API Keys"
# 4. Paste your real values below (never commit .env.local)
# ===========================================

# Your app's API key (secret – keep this private, server-side only)
# Dashboard: Your App → API Keys → reveal & copy
WHOP_API_KEY=

# Your app ID (starts with app_ – safe to expose in client code)
# Dashboard: Your App → App Settings → App ID
NEXT_PUBLIC_WHOP_APP_ID=

# Webhook signing secret (only needed if you use webhooks)
# Dashboard: Your App → Webhooks → create webhook → copy secret
# Leave empty until you add a webhook.
WHOP_WEBHOOK_SECRET=
